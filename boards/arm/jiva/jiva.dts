/dts-v1/;
#include <nordic/nrf52832_qfaa.dtsi>


/* Generated */
/ {
	model = "jiva";
	compatible = "ligna-energy,jiva";

	chosen {
		zephyr,sram = &sram0;
		zephyr,flash = &flash0;
		zephyr,code-partition = &slot0_partition;
	};
};

&flash0 {
	partitions {
		compatible = "fixed-partitions";
		#address-cells = <1>;
		#size-cells = <1>;

		boot_partition: partition@0 {
			label = "mcuboot";
			reg = <0x0 0xc000>;
		};
		slot0_partition: partition@c000 {
			label = "image-0";
			reg = <0xc000 0x32000>;
		};
		slot1_partition: partition@3e000 {
			label = "image-1";
			reg = <0x3e000 0x32000>;
		};
		scratch_partition: partition@70000 {
			label = "image-scratch";
			reg = <0x70000 0xa000>;
		};
		storage_partition: partition@7a000 {
			label = "storage";
			reg = <0x7a000 0x6000>;
		};
	};
};

/* Should not be contected here */
// P0.00 & P0.01  crystal
// NC P0.02, P0.03, P0.04, P0.05, P0.07, P0.11, P0.13,P0.14,P0.15,
// P0.16,P0.20, P0.22, P0.24,P0.27,P0.28,P0.29,P0.30,P0.31

/* Added */

/ {

    chosen {
		zephyr,console = &uart0;
    };

	gpo{
        compatible = "gpio-leds";

        led0: led_0 {
			gpios= <&gpio0 25 GPIO_ACTIVE_HIGH>; // GPIO_ACTIVE_LOW in blinky example
			label= "Debug led P0.25 / D2";
		};
		tmpon: tmp_on {
			gpios= <&gpio0 6 GPIO_ACTIVE_HIGH>; 
			label= "I2C enable pin";
		};
		gpo0: gpo_0 {
			gpios= <&gpio0 19 GPIO_ACTIVE_HIGH>; 
			label= "General purpose outpin P0.19";
		};
		gpo1: gpo_1 {
			gpios= <&gpio0 23 GPIO_ACTIVE_HIGH>; 
			label= "General purpose outpin P0.23";
		};

    };

	gpi{
		compatible = "gpio-keys";
		alert: alert {
			gpios = < &gpio0 12 (GPIO_PULL_UP | GPIO_ACTIVE_LOW)>; // todo check config
			label = "Alert from I2C temp sensor";
		};
		button0: button_0 {
			gpios = < &gpio0 26 (GPIO_PULL_UP | GPIO_ACTIVE_LOW)>;
			label = "Push button switch 0";
		};
	};

};

&gpio0 {
    status  = "okay";
};

&gpiote {
    status = "okay";
};


&i2c0 {
	pinctrl-0 = <&i2c0_default>;
	pinctrl-1 = <&i2c0_sleep>;
	pinctrl-names = "default", "sleep";
};

&uart0 {
    status = "okay";
    current-speed = < 0x1c200 >;
    pinctrl-0 = < &uart0_default >;
    pinctrl-1 = < &uart0_sleep >;
    pinctrl-names = "default", "sleep";
};

&pinctrl {
    i2c0_default: i2c0_default {
		group1 {
			psels = <NRF_PSEL(TWIM_SDA, 0, 10)>,
					<NRF_PSEL(TWIM_SCL, 0, 8)>;
		};
	};

	i2c0_sleep: i2c0_sleep {
		group1 {
			psels = <NRF_PSEL(TWIM_SDA, 0, 10)>,
					<NRF_PSEL(TWIM_SCL, 0, 8)>;
			low-power-enable;
		};
	};

	uart0_default: uart0_default {
		group1 {
			psels = <NRF_PSEL(UART_TX, 0, 17)>;
				//<NRF_PSEL(UART_RX, 0, xx)>,
				//<NRF_PSEL(UART_RTS, 0, xx)>,
				//<NRF_PSEL(UART_CTS, 0, xx)>;
		};
	};

	uart0_sleep: uart0_sleep {
		group1 {
			psels = <NRF_PSEL(UART_TX, 0, 17)>;
				//<NRF_PSEL(UART_RX, 0, xx)>,
				//<NRF_PSEL(UART_RTS, 0, xx)>,
				//<NRF_PSEL(UART_CTS, 0, xx)>;
			low-power-enable;
		};
	};
};






/dts-v1/;
#include <nordic/nrf52832_qfaa.dtsi>
#include "Gwen-pinctrl.dtsi"

/ {
	model = "Custom Board auto generated by nRF Connect for VS Code";
	compatible = "LignaEnergy,Gwen";

	chosen {
		zephyr,sram = &sram0;
		zephyr,flash = &flash0;
		zephyr,code-partition = &slot0_partition;
	};
};

&flash0 {
	partitions {
		compatible = "fixed-partitions";
		#address-cells = <1>;
		#size-cells = <1>;

		boot_partition: partition@0 {
			label = "mcuboot";
			reg = <0x00000000 DT_SIZE_K(48)>;
		};

		slot0_partition: partition@c000 {
			label = "image-0";
			reg = <0x0000c000 DT_SIZE_K(220)>;
		};

		slot1_partition: partition@43000 {
			label = "image-1";
			reg = <0x00043000 DT_SIZE_K(220)>;
		};

		storage_partition: partition@7a000 {
			label = "storage";
			reg = <0x0007a000 DT_SIZE_K(24)>;
		};
	};
};

// p0.05 ADC-vcap
// p0.07 led
// p0.08 tmpon, p0.09 scl, p0.10 sda
// uart tx p023 (or p022 in your custom), swo p022
// swclk, swdio

/ {
	zephyr,user {
		io-channels = <&adc 0>;
	};

    chosen {
		zephyr,console = &uart0;
    };

	gpo {
        compatible = "gpio-leds";

        led0: led_0 {
			gpios = <&gpio0 7 GPIO_ACTIVE_HIGH>; // Debug LED on P0.07
			label = "Debug led P0.07";
		};
		tmpon: tmp_on {
			gpios = <&gpio0 8 GPIO_ACTIVE_HIGH>; // I2C enable pin on P0.08
			label = "I2C enable pin";
		};
    };
};

&gpio0 {
    status = "okay";
};

&gpiote {
    status = "okay";
};

&i2c0 {
    pinctrl-0 = <&i2c0_default>;
    pinctrl-1 = <&i2c0_sleep>;
    pinctrl-names = "default", "sleep";
    status = "okay";   // <-- ensure i2c0 is enabled

    /* ---- Added SHT4x sensor node ---- */
    sht4x@44 {
        compatible = "sensirion,sht4x";   // driver binding
        reg = <0x44>;                     // I²C address (0x44 or 0x45 possible)
        repeatability = <0>;              // lowest power mode (can change)
        label = "SHT4X";                  // name used by drivers
    };
    /* --------------------------------- */
};

&uart0 {
    status = "okay";
    current-speed = <0x1c200>;
    pinctrl-0 = <&uart0_default>;
    pinctrl-1 = <&uart0_sleep>;
    pinctrl-names = "default", "sleep";
};

&pinctrl {
    status = "okay";

    i2c0_default: i2c0_default {
		group1 {
			psels = <NRF_PSEL(TWIM_SDA, 0, 10)>,
			        <NRF_PSEL(TWIM_SCL, 0, 9)>;
		};
	};

	i2c0_sleep: i2c0_sleep {
		group1 {
			psels = <NRF_PSEL(TWIM_SDA, 0, 10)>,
			        <NRF_PSEL(TWIM_SCL, 0, 9)>;
			low-power-enable;
		};
	};

	uart0_default: uart0_default {
		group1 {
			// psels = <NRF_PSEL(UART_TX, 0, 23)>;
			psels = <NRF_PSEL(UART_TX, 0, 22)>;
		};
	};

	uart0_sleep: uart0_sleep {
		group1 {
			// psels = <NRF_PSEL(UART_TX, 0, 23)>;
			psels = <NRF_PSEL(UART_TX, 0, 22)>;
			low-power-enable;
		};
	};
};

&adc {
	#address-cells = <1>;
	#size-cells = <0>;

	channel@0 {
		reg = <0>;
		zephyr,gain = "ADC_GAIN_1_6";
		zephyr,reference = "ADC_REF_INTERNAL";
		zephyr,acquisition-time = <ADC_ACQ_TIME_DEFAULT>;
		zephyr,input-positive = <NRF_SAADC_AIN3>;   /* measuring P0.05 */
		//zephyr,resolution = <14>;
		//zephyr,oversampling = <8>;
		zephyr,resolution = <10>;
		zephyr,oversampling = <0>;
	};
	status = "okay";
};